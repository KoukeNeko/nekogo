{
  "name": "nekogo",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/noto-sans-jp": "^0.4.3",
    "@expo/ui": "~56.0.18",
    "@expo/vector-icons": "^15.0.2",
    "@op-engineering/op-sqlite": "^16.2.2",
    "@react-native-masked-view/masked-view": "0.3.2",
    "expo": "~56.0.12",
    "expo-asset": "~56.0.17",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.7",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.11",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-speech": "~56.0.3",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "lucide-react-native": "^1.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "ts-fsrs": "^5.4.1"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "kuromoji": "^0.1.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:device": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 expo run:ios --device --configuration Release",
    "web": "expo start --web",
    "lint": "expo lint",
    "seed:download": "node scripts/etl/download-sources.mjs",
    "seed:build": "node scripts/etl/build-vocab-seed.mjs",
    "seed:verify": "node scripts/verify-vocab-seed.mjs",
    "seed": "npm run seed:download && npm run seed:build && npm run seed:verify",
    "kanji:download": "node scripts/etl/download-kanji-sources.mjs",
    "kanji:build": "node scripts/etl/build-kanji-data.mjs",
    "kanji:verify": "node scripts/verify-kanji-data.mjs",
    "kanji": "npm run kanji:download && npm run kanji:build && npm run kanji:verify",
    "extra:download": "node scripts/etl/download-vocab-extra-sources.mjs",
    "extra:build": "node scripts/etl/build-vocab-extra.mjs",
    "extra:verify": "node scripts/verify-vocab-extra.mjs",
    "extra": "npm run extra:download && npm run extra:build && npm run extra:verify",
    "content:download": "npm run seed:download && npm run kanji:download && npm run extra:download && node scripts/etl/download-jmdict-common.mjs",
    "content:setup": "python3 -m venv scripts/etl/.venv && scripts/etl/.venv/bin/pip install -q -r scripts/etl/requirements.txt",
    "content:build": "node scripts/etl/build-content-db.mjs && npm run content:enrich",
    "content:enrich": "scripts/etl/.venv/bin/python scripts/etl/enrich-pitch-freq.py",
    "content:verify": "node scripts/verify-content-db.mjs",
    "content": "npm run content:download && npm run content:build && npm run content:verify",
    "data": "npm run seed && npm run kanji && npm run extra"
  },
  "private": true
}
