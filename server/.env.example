SERVER_ADDR=:8090

# Irodori Gradio HTTP API on the GPU host. Use "openai" only when the
# separate OpenAI-compatible Irodori-TTS-Server is actually running.
IRODORI_API_MODE=gradio
IRODORI_BASE_URL=http://192.168.50.169:7860
IRODORI_GRADIO_CHECKPOINT=Aratako/Irodori-TTS-500M-v3
IRODORI_API_KEY=
FFMPEG_PATH=ffmpeg

# Optional app-facing bearer token. Keep empty for the initial LAN-only build.
# A static token embedded in a mobile app is not a production secret.
APP_API_KEY=

DATABASE_PATH=./data/tts.db
AUDIO_DIR=./data/audio
# Read-only copy of the same versioned content DB bundled in the App.
CONTENT_DATABASE_PATH=../assets/db/kioku-content.db
# Optional JSON object mapping entry_id to a human-reviewed pronunciation string.
TTS_OVERRIDES_FILE=./tts-overrides.json
DEFAULT_VOICE=dictionary-ja-01
DEFAULT_FORMAT=m4a
DEFAULT_SPEED=1.0
APPROVED_VOICES=dictionary-ja-01,none

IRODORI_MODEL_NAME=irodori-tts
MODEL_REVISION=Irodori-TTS-500M-v3
VOICE_VERSION=v1
PROFILE_VERSION=quality-v2-no-trim
IRODORI_NUM_STEPS=60
IRODORI_REQUEST_TIMEOUT=5m
MAX_CONCURRENT_SYNTHESIS=1
RATE_LIMIT_PER_MINUTE=60
MAX_AUDIO_MIB=16
