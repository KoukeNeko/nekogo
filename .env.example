# 複製本檔為 .env.local（已被 .gitignore 的 ".env*.local" 規則忽略）再填值。
# EXPO_PUBLIC_ 前綴的變數 Expo 會自動載入並內嵌進 App bundle（皆為公開值，非密鑰）。

# ── 伺服器位址 ─────────────────────────────────────────────────
# 內容 + 登入 API 的 base URL。留空時自動用「Metro host:4000」（模擬器／同網段實機、
# 伺服器跑在同一台 Mac 時免設）。指向已部署伺服器、別台機器或 tunnel 時才填。
# 例：EXPO_PUBLIC_API_URL=https://api.example.com   或   http://192.168.1.20:4000
EXPO_PUBLIC_API_URL=

# ── 登入（之後做同步時才需要；現在可全留空，App 以 guest 執行）──────────
# Google OAuth client ID（Google Cloud Console → APIs & Services → Credentials，建 iOS + Web client）。
# 填了 Web client id 後，登入功能會自動啟用（AUTH_ENABLED）。
# Web client ID：App（webClientId）與後端（GOOGLE_WEB_CLIENT_ID）共用，作為 idToken 的 aud。
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# iOS client ID：原生 Google 登入用；app.config.js 會由它自動推導 iOS URL scheme。
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# 想在「未設 Google」時仍強制開啟登入（例如只測 Apple）才設為 true；一般不用。
# EXPO_PUBLIC_AUTH_ENABLED=true
